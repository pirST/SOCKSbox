{
  "manifest_version": 3,
  "name": "SOCKSbox",
  "version": "0.5.1",
  "description": "Extension to manage multiple SOCKS5 and HTTP proxies",
  "permissions": ["proxy", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}
